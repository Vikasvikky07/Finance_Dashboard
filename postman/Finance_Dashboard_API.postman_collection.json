                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set('token', json.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
